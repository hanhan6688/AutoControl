APP_NAME=Mobile AI TestOps
DATABASE_URL=sqlite:///./mobile_ai_testops.db
# MySQL example:
# DATABASE_URL=mysql+pymysql://mobile_ai_testops:password@127.0.0.1:3306/mobile_ai_testops?charset=utf8mb4
# Python virtual environment path (relative to project root or absolute)
# Leave empty to use system Python
PYTHON_PATH=.venv
# Leave tool paths empty to auto-resolve from ./tools first, then system PATH.
ADB_PATH=
IOS_PATH=
HDC_PATH=
SCRCPY_PATH=
FFMPEG_PATH=
MAESTRO_PATH=
# agent-browser CLI path for PC/Web automation (auto-resolved if empty)
AGENT_BROWSER_PATH=
# Optional local APK used to auto-install ADB Keyboard on new Android devices.
# Example: tools/ADBKeyboard.apk
ADB_KEYBOARD_APK_PATH=
AUTOGLM_BASE_URL=http://localhost:8000/v1
AUTOGLM_MODEL=autoglm-phone-9b
AUTOGLM_API_KEY=EMPTY
AUTOGLM_MAX_STEPS=100
AUTOGLM_LANG=cn
AUTOGLM_WDA_URL=http://localhost:8100
# PC/Web Agent AI. It decides the next browser action for agent-browser.
# This is intentionally separate from mobile Open-AutoGLM and case planning.
PC_AGENT_ENABLED=true
PC_AGENT_PROVIDER=minimax_auto
PC_AGENT_BASE_URL=https://api.minimaxi.com/v1
PC_AGENT_MODEL=MiniMax-M2.7
PC_AGENT_API_KEY=EMPTY
PC_AGENT_TIMEOUT_SECONDS=30
PC_AGENT_TEMPERATURE=0.1
PC_AGENT_MAX_TOKENS=300
# Result assertion AI. It judges whether a completed AutoGLM run actually satisfies the expected result.
# Keep this separate from AutoGLM execution; it is the judge, not the phone operator.
RESULT_ASSERTION_ENABLED=true
RESULT_ASSERTION_BASE_URL=https://api.minimaxi.com/v1
RESULT_ASSERTION_MODEL=MiniMax-M2.7
RESULT_ASSERTION_API_KEY=EMPTY
RESULT_ASSERTION_TIMEOUT_SECONDS=20
# Timeout for device screenshot capture operations.
SCREENSHOT_TIMEOUT_SECONDS=20
AUTOMATION_TARGET_APP_NAME=
# ZAP security scanning (requires OWASP ZAP CLI in tools/zap/ or system PATH)
ZAP_ENABLED=false
ZAP_API_KEY=
ZAP_PROXY_HOST=127.0.0.1
ZAP_PROXY_PORT=8080
ZAP_PATH=
# API test default timeout in seconds
API_TEST_DEFAULT_TIMEOUT=30
OCR_BASE_URL=http://127.0.0.1:1224
# Android web screen streaming. auto resolves to scrcpy-ffmpeg-mjpeg for embedded Electron/web preview.
# The UI requests 15 FPS by default for stability; raise it from the frontend only after the device/browser path is stable.
ANDROID_STREAM_PROVIDER=scrcpy-ffmpeg-mjpeg
MINICAP_PORT_START=1717
SCRCPY_WEB_PORT_START=28183
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:5174","http://127.0.0.1:5174","http://localhost:5175","http://127.0.0.1:5175"]
