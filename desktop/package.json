{
  "name": "mobile-ai-testops",
  "version": "1.0.0",
  "private": true,
  "description": "Mobile AI TestOps",
  "author": "Mobile AI TestOps",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "cross-env ELECTRON_DEV=true electron .",
    "build:win": "electron-builder --win"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.testops.mobile-ai",
    "productName": "Mobile AI TestOps",
    "files": [
      "main.js",
      "preload.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../frontend/dist",
        "to": "frontend/dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "app/**",
          "requirements.txt",
          ".env.example",
          "scripts/**",
          "static/uploads/.gitkeep",
          "!**/__pycache__/**",
          "!**/.pytest_cache/**",
          "!**/*.db",
          "!**/.env"
        ]
      },
      {
        "from": "../tools/scrcpy-win64",
        "to": "tools/scrcpy-win64",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../tools/ffmpeg",
        "to": "tools/ffmpeg",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../tools/agent-browser",
        "to": "tools/agent-browser",
        "filter": [
          "package.json",
          "package-lock.json",
          "node_modules/**"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    }
  }
}
